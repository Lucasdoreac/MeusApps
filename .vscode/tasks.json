{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build: windows (audit)",
      "type": "shell",
      "command": "bash scripts/ci.sh",
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build: windows (fast)",
      "type": "shell",
      "command": "bash scripts/ci.sh --fast",
      "group": "build"
    },
    {
      "label": "build: android",
      "type": "shell",
      "command": "bash scripts/ci.sh --target android",
      "group": "build"
    },
    {
      "label": "run: windows",
      "type": "shell",
      "command": "dotnet run --project primeiroApp.csproj -f net10.0-windows10.0.19041.0",
      "group": "test"
    }
  ]
}
