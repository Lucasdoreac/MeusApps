<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="primeiroApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:primeiroApp.Pages"
    Shell.NavBarIsVisible="False"
    Shell.TabBarBackgroundColor="{StaticResource LudocBg1}"
    Shell.TabBarForegroundColor="{StaticResource LudocGreen}"
    Shell.TabBarUnselectedColor="{StaticResource LudocDim}"
    Shell.TabBarTitleColor="{StaticResource LudocGreen}">

    <TabBar>
        <ShellContent
            Title="CHAT"
            Route="ChatPage"
            ContentTemplate="{DataTemplate pages:ChatPage}"/>

        <ShellContent
            Title="STATUS"
            Route="DashboardPage"
            ContentTemplate="{DataTemplate pages:DashboardPage}"/>

        <ShellContent
            Title="CONFIG"
            Route="SettingsPage"
            ContentTemplate="{DataTemplate pages:SettingsPage}"/>

        <ShellContent
            Title="VOICE"
            Route="VoicePage"
            ContentTemplate="{DataTemplate pages:VoicePage}"/>
    </TabBar>

</Shell>
