<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:primeiroApp.Converters"
             x:Class="primeiroApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters globais -->
            <conv:SenderColorConverter     x:Key="SenderColorConverter"/>
            <conv:SenderTextColorConverter x:Key="SenderTextColorConverter"/>
            <conv:IntToProgressConverter   x:Key="IntToProgressConverter"/>
            <conv:RamToProgressConverter   x:Key="RamToProgressConverter"/>
            <conv:OnlineStatusConverter    x:Key="OnlineStatusConverter"/>
            <conv:OnlineColorConverter     x:Key="OnlineColorConverter"/>
            <conv:TaskStatusColorConverter  x:Key="TaskStatusColorConverter"/>
            <conv:ThresholdColorConverter  x:Key="ThresholdColorConverter"/>
            <conv:RamColorConverter        x:Key="RamColorConverter"/>
            <conv:DiskColorConverter       x:Key="DiskColorConverter"/>
            <conv:PagefileColorConverter   x:Key="PagefileColorConverter"/>
            <conv:IntToBoolConverter       x:Key="IntToBoolConverter"/>
            <conv:InvertedBoolConverter    x:Key="InvertedBoolConverter"/>
            <conv:VoiceButtonColorConverter x:Key="VoiceButtonColorConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
